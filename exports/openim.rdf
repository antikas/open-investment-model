        <rdfs:comment>OpenIM relation verb — reference, n-to-1. Inverse: HELD_VIA_INVESTMENT.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/openim/ontology/PM-09"/>
        <rdfs:label>HOLDS_INTEREST_IN</rdfs:label>

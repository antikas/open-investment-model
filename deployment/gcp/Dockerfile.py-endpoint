# Dockerfile for the Python agentINVEST endpoint.
FROM python:3.12-slim

WORKDIR /app
COPY reference/python/pyproject.toml reference/python/uv.lock ./
COPY reference/python/ .

RUN pip install --upgrade pip && pip install uv
RUN uv sync

ENV RESTATE_ADMIN_URL=http://localhost:9070
ENV AGENTINVEST_PY_ENDPOINT_PORT=9091

EXPOSE 9091

CMD ["uv", "run", "python", "-m", "agentinvest_tools.endpoint"]

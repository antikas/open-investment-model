# Primary-spine FKs added under the 2026-05-24 entity-model audit —
# closes the audit's M1..M5 gaps where the entity attribute schemas
# declare these FKs but the conceptual diagrams did not edge them.
# ──────────────────────────────────────────────────────────────────

E_03_Portfolio.parent_portfolio_id -> E_03_Portfolio.portfolio_id: "parent of (sub-portfolio)"
E_03_Portfolio.asset_class -> E_09_AssetClass.asset_class_id: "asset-class portfolio"
E_05_Transaction.counterparty_entity_id -> E_01_LegalEntity.legal_entity_id: "counterparty"
E_06_CashFlowEvent.portfolio_id -> E_03_Portfolio.portfolio_id: "cash in / out"
E_06_CashFlowEvent.instrument_id -> E_02_Instrument.instrument_id: "concerning"
E_18_LimitBreach.measurement_id -> E_19_RiskMeasurement.measurement_id: "measurement that crossed"

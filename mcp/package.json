{
  "name": "@openinvestmentmodel/openim-mcp",
  "version": "0.1.1",
  "description": "Read-only MCP server for the Open Investment Model, with versioned and source-cited model retrieval.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "openim-mcp": "dist/server.js"
  },
  "files": [
    "dist/LICENSE",
    "dist/model-index.json",
    "dist/server.js",
    "dist/server.js.LEGAL.txt",
    "dist/THIRD_PARTY_NOTICES.txt",
    "README.md",
    "server.json"
  ],
  "mcpName": "io.github.antikas/openim",
  "license": "MIT",
  "author": "Georgios Antikatzidis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antikas/open-investment-model.git",
    "directory": "mcp"
  },
  "homepage": "https://openinvestmentmodel.org/",
  "bugs": {
    "url": "https://github.com/antikas/open-investment-model/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "investment-management",
    "asset-management",
    "buy-side",
    "reference-model",
    "canonical-data-model"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:index": "node scripts/build-index.mjs",
    "build:manifest": "node scripts/build-manifest.mjs",
    "build:runtime": "node scripts/build-runtime.mjs",
    "build:tests": "tsc -p tsconfig.test.json",
    "build": "npm run clean && npm run build:index && npm run build:manifest && npm run build:runtime",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && npm run typecheck && npm run build:tests && node --test dist/tests/*.test.js",
    "audit:production": "npm audit --omit=dev",
    "check:bundle": "node scripts/quality-gates.mjs bundle",
    "check:consumer": "node scripts/quality-gates.mjs consumer",
    "check:reproducible": "node scripts/quality-gates.mjs reproducible",
    "quality": "npm run audit:production && npm test && npm run check:bundle && npm run check:consumer && npm run check:reproducible",
    "prepack": "npm run build && npm run check:bundle"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^24.10.0",
    "esbuild": "^0.28.1",
    "zod": "^4.4.3",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "@hono/node-server": "2.0.11"
  }
}

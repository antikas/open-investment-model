    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/openim/ontology/vehicle-holds">
    <rdfs:comment>Inverse of openim:held-through-vehicle (reference, n-to-1).</rdfs:comment>

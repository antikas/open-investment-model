      <owl:ObjectProperty rdf:about="https://w3id.org/openim/ontology/in-portfolio">
        <rdfs:comment>OpenIM relation verb — reference, n-to-1. Inverse: PORTFOLIO_INCLUDES.</rdfs:comment>
        <rdfs:domain>
          <owl:Class rdf:nodeID="cb1b5f5102fc6fa80fb238ab95965cd767a584ba8a357775a7dfc5b903a6a8c08a7">
            <owl:unionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/E-04"/>
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/E-05"/>
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/E-06"/>
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/PB-03"/>
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/PB-05"/>
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/PB-06"/>
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/PB-11"/>
            </owl:unionOf>
          </owl:Class>
        </rdfs:domain>
        <rdfs:label>IN_PORTFOLIO</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/openim/ontology/E-03"/>
        <owl:inverseOf rdf:resource="https://w3id.org/openim/ontology/portfolio-includes"/>
      </owl:ObjectProperty>

# agentINVEST workspace — ignored build/runtime artefacts.

# Node / pnpm
node_modules/
dist/
.turbo/

# Audit-journal export output — hash-chained JSON-L + manifest are RUNTIME DATA, never
# committed. Default output dir `.audit-export/` under reference/ (workspace script) or reference/ts/.
.audit-export/

# Next.js (the Operator UI, reference/operator-ui) — build output + dev cache.
.next/
next-env.d.ts
# Playwright MCP artefacts (screenshots/snapshots captured during a UI proof).
.playwright-mcp/

# OpenIM-owned Restate binaries (downloaded by scripts/install-restate.mjs;
# version-pinned, never committed — they are platform-specific and large).
tools/
.restate-dev/

# Python / uv
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Logs
*.log

# dbt — build artefacts (compiled SQL, run results, packages, logs). The dbt
# SOURCE (dbt/dbt_project.yml, dbt/profiles.yml, dbt/models, dbt/seeds) IS
# committed; only generated output is ignored.
dbt/target/
dbt/logs/
dbt/dbt_packages/
dbt/.user.yml
# The duckdb canonical-data FILE lives on WSL2-native ext4, NOT in the
# repo — but ignore any *.duckdb here defensively in case a profile override or
# a Mac/Linux run is misconfigured to write under the repo tree.
*.duckdb
*.duckdb.wal

# Windows-path-as-relative-dir leak guard.
# A script/tool that receives a Windows-style absolute path
# (any drive-lettered absolute path) as a RELATIVE dir argument — e.g. an
# unexpanded `~` or a Windows $HOME leaking into a tool whose cwd is reference/ —
# creates a stray drive-lettered tree under reference/. The root-cause fix
# is that the launchers always export an absolute, already-expanded duckdb/venv
# path (scripts/dbt-build.sh); this guard catches the drive-lettered/`~` tree
# class under reference/ if a future invocation regresses it. NOTE: the SEPARATE
# uv-cwd-fallback class (a glitched uv writing a normal-named pyproject.toml/
# uv.lock at the REPO ROOT) is guarded by the root-anchored /pyproject.toml +
# /uv.lock in the repo-root .gitignore, not here.
[A-Za-z]:/
~/

# Workstation deploy — runtime markers + the deploy log. The
# `deploy/.run/` dir holds per-surface *.marker.json (the spawned-by-us ledger
# teardown reads) + deploy.log; all RUNTIME artefacts, never committed. (`*.log`
# above already covers the log; this ignores the marker ledger too.)
deploy/.run/

# scratch-file convention — throwaway probe/test/scratch files are never committed.
_probe-*
_test-*
_scratch-*

        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="https://w3id.org/openim/ontology/PM-01"/>
          <rdf:Description rdf:about="https://w3id.org/openim/ontology/PM-04"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:label>HELD_VIA_INVESTMENT</rdfs:label>

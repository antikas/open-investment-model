        <rdfs:comment>OpenIM relation verb — reference, n-to-1. Inverse: GENERATES.</rdfs:comment>
        <rdfs:domain>
          <owl:Class rdf:nodeID="cb200a5e0e65da68f806477bb092fa212ade9be97b35f666015b0d42d661857fd9b">
            <owl:unionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/E-06"/>
              <rdf:Description rdf:about="https://w3id.org/openim/ontology/PB-07"/>

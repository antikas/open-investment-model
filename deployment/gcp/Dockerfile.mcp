# Dockerfile for the MCP stdio sidecar.
FROM python:3.12-slim

WORKDIR /app
COPY reference/python/pyproject.toml reference/python/uv.lock ./
COPY reference/python/ .

RUN pip install --upgrade pip && pip install uv
RUN uv sync

ENV AGENTINVEST_RESTATE_INGRESS_URL=http://localhost:8080
ENV AGENTINVEST_MCP_LOG_LEVEL=INFO

CMD ["uv", "run", "python", "-m", "agentinvest_tools.mcp_server"]

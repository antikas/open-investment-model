          <rdf:Description rdf:about="https://w3id.org/openim/ontology/E-10"/>
          <rdf:Description rdf:about="https://w3id.org/openim/ontology/FO-01"/>
          <rdf:Description rdf:about="https://w3id.org/openim/ontology/FO-02"/>
          <rdf:Description rdf:about="https://w3id.org/openim/ontology/FO-06"/>

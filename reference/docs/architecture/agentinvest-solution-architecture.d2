# agentINVEST — solution architecture (deployment / runtime / component view).
#
# A technology-named runtime view of agentINVEST, the OpenIM reference
# implementation. It is the SOLUTION view (real tech, real topology), NOT the
# logical BD/SD capability model.
#
# Topology vocabulary is ratified in the project's stack-and-topology decision
# record: ONE orchestrating loop (the InvestmentOperation virtual object's plan
# step); the per-Business-Domain layer is model-free Restate *services*, NOT
# agents; the 171 SD / ~1,030 SO decomposition is a typed *tool catalogue*, not
# a fleet of loops.
#
# Honest current-state: solid-filled boxes are BUILT (exist in reference/
# today). Dashed boxes are PLANNED / decided-but-not-built. See the legend.
#
# A Mermaid mirror of this diagram lives at ./agentinvest-solution-architecture.md.

vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: down

# Shared classes — BUILT (solid) vs PLANNED (dashed).
classes: {
  built: {
    style: {fill: "#1f3a5f"; font-color: "#ffffff"; bold: true; stroke: "#0e1e33"}
  }
  built-soft: {
    style: {fill: "#dfe8f7"; stroke: "#5b7aa6"; font-color: "#1f3a5f"}
  }
  planned: {
    style: {fill: "#f0eee6"; stroke: "#a09578"; font-color: "#5a513a"; stroke-dash: 4}
  }
  group: {
    style: {fill: "#f7f8fb"; stroke: "#5b7aa6"; font-color: "#1f3a5f"}
  }
  group-planned: {
    style: {fill: "#faf8f2"; stroke: "#a09578"; font-color: "#5a513a"; stroke-dash: 4}
  }
}

# ─────────────────────────────────────────────────────────
# Legend.
# ─────────────────────────────────────────────────────────
legend: "Legend" {
  near: top-left
  class: group
  built_key: "BUILT — exists in reference/ today" {class: built}
  planned_key: "PLANNED — decided, not yet built" {class: planned}
}

# ─────────────────────────────────────────────────────────
# Channels / surfaces — how callers reach agentINVEST.
# ─────────────────────────────────────────────────────────
surfaces: "Channels & surfaces" {
  class: group

  cli: "agentinvest-cli\nTypeScript (tsx)\nbootstrap · seed · serve\n[BUILT]" {class: built}

  mcp: "MCP server\nstdio sidecar · catalogue → MCP tool descriptors\ndispatches to the bd09 / bd12 / bd12Recon services (journaled)\n[BUILT]" {class: built-soft}

  openapi: "OpenAPI surface\nRestate auto-gen 3.1 · self-served /openapi.json + /docs\nprogrammatic / human ingress\n[BUILT]" {class: built}

  ui: "Operator UI\nNext.js + Tailwind (TypeScript) · server-side fetch from admin + ingress · no app-auth (v0.1)\napprovals (list + approve/reject the gate) · operations (read-only journal + audit record) · deployments · canonical-data inspector (read-only)\n[BUILT: all 4 pages — Approvals + Operations + Deployments + Canonical-data inspector]" {class: built-soft}
}

# ─────────────────────────────────────────────────────────
# The durable-execution substrate — Restate.
# ─────────────────────────────────────────────────────────
substrate: "Restate — durable-execution substrate" {
  class: group

  engine: "restate-server\nself-hosted single binary · local dev instance (in WSL2 on Windows)\nproject-owned launcher + version pin\nadmin :9070 · ingress :8080\nimmutable deployments + pinned executions · version-skew gate\n[BUILT — pinned v1.6.2]" {class: built}

  journal: "Durable journal\noperational audit · replay-grade reproducibility\nsqlite (dev) → Postgres (prod)\n[BUILT-by-substrate]" {class: built-soft}
}

# ─────────────────────────────────────────────────────────
# agentINVEST runtime — handlers registered with Restate.
# ─────────────────────────────────────────────────────────
runtime: "agentINVEST runtime — Restate-registered handlers" {
  class: group

  # The single orchestrating loop's home.
  orchestrator: "InvestmentOperation\nRestate virtual object · keyed by operationId\nTypeScript (Restate TS SDK) · TS endpoint :9090\nSEAMS: plan(BUILT) → resolve(BUILT) → dispatch(BUILT) → approve(BUILT) → aggregate(BUILT) → close(BUILT)\n[BUILT — the whole orchestrator loop: version-skew gate + .plan() + arg-resolution + dispatch + approval gate + aggregate + audit-record close]" {class: built}

  plan_loop: "The single reasoning loop — .plan()\nagentinvestPlanner (Python) · Anthropic Sonnet 4.6 structured output (forced tool-use)\nPlanSchema-validated plan · journaled exactly once · tool-RAG seam\n[BUILT — the one LLM loop]" {class: built-soft}

  approval: "HighStakesApprovalGate\nawaitable approval step (Restate ctx.awakeable · durable pause)\nriskScore >= threshold → pause · approve/reject/timeout · terminal abort\nreusable component (not a second loop) · provisional threshold/timeout\n[BUILT — mechanism + forced-fire proof, not wired to fire for read-only by default]" {class: built-soft}

  nav_workflow: "NavCalculationWorkflow\nRestate workflow · keyed per strike · TypeScript (Restate TS SDK)\nload-positions → price → apply-fees → roll-up → [GATE] → publish\nmulti-step journaled · crash-recoverable · publish exactly-once (internal journal)\nreuses the approval gate at publish · cross-mart reconcile (holdings ↔ mart_fund_nav gross) + the NAV identity · past-as-of refused on the wire\n[BUILT — first real high-stakes gate wiring; synthetic NAV, current-as-of]" {class: built-soft}

  arg_resolver: "argResolver service\nPython (Restate Python SDK) · the resolve step's marts-read seam\nabstract plan-step args → concrete tool inputs (begin/end NAV · per-segment weights+returns)\nreuses the marts→input derivation · journaled · bounded to the BD-09 return tools (SO-09-01/05)\nunresolvable step → clean failure (never fabricated inputs)\n[BUILT — deterministic, model-free; a general resolver for the full catalogue is forward]" {class: built-soft}

  fanout: "Ephemeral fan-out subagents\nspawned only for independent legs\n[PLANNED]" {class: planned}

  recon_propose: "Propose-only AI stage over unexplained breaks\nexplanation proposals only · never a state mutation · never in the truth path\n[PLANNED — designed, not built]" {class: planned}

  recon_correct: "Correction workflow — the first state-mutating write\ncorrecting entry to the books behind the high-stakes approval gate\n[PLANNED — not built]" {class: planned}

  # The per-BD layer — model-free SERVICES, not agents.
  bd_services: "Per-Business-Domain layer — model-free Restate SERVICES (not agents)" {
    class: group

    pytools: "pyTools service\nPython (Restate Python SDK) · Python endpoint :9091\ntool-hosting / dispatch boundary · no reasoning loop\n[BUILT — placeholder service + computeSimpleReturn]" {class: built}

    placeholder: "agentinvestPlaceholder service\nTypeScript · journal-replay proof handler\n[BUILT]" {class: built-soft}

    bdNN: "Per-BD model-free services (one per BD)\nPython · execute_so dispatch + list_capabilities · journaled steps\ndeterministic-error → Restate TerminalError (no retry storm)\n[BUILT: bd09 — 5 performance SOs · bd12 — 9 IBOR/ABOR read SOs · further BDs PLANNED]" {class: built-soft}

    recon: "bd12Recon service — the SD-12.10 reconciliation engine\nPython · deterministic dual-pipeline reconcile (position · cash · transaction-match · IBOR/ABOR)\nreads the internal dual book + the external comparator feeds · deterministic cause classification\nappends findings to the break store (insert-only) · no LLM in the truth path\n[BUILT — complete and audited]" {class: built-soft}
  }

  # The typed tool catalogue (capability axis, NOT the agent axis).
  tools: "Typed tool catalogue — per-Service-Operation functions\nPython + Pydantic over the canonical model\n171 SD / ~1,030 SO = tools (not agents)\n[BUILT: 19 tools — 5 BD-09 return (oracle-tested) + 9 BD-12 IBOR/ABOR read + 4 SD-12.10 reconcile + 1 sample · the rest of the ~1,030 PLANNED]" {class: built-soft}
}

# ─────────────────────────────────────────────────────────
# Canonical data layer — dbt.
# ─────────────────────────────────────────────────────────
data: "Canonical data layer — dbt" {
  class: group

  schemas: "Canonical model schemas\n@agentinvest/canonical-model · Python + Pydantic\nthirteen canonical entities (incl. the dual-book E-04/E-05/E-06 + the E-24 break) + schema-drift check vs model/\n[BUILT]" {class: built}

  dbt: "dbt project (reference/dbt/)\ndbt-duckdb (dev) → dbt-postgres (prod)\nstaging + intermediate (bi-temporal) + marts BUILT\ndual-book (IBOR/ABOR) staging + external comparator feeds BUILT\nmart_fund_nav: NAV = Σmv + accruals − fees\n[BUILT]" {class: built}

  store: "Canonical store\nduckdb (dev — on WSL2-native ext4 on Windows) · keyed per checkout\nsynthetic seed: 3 funds · bi-temporal as-of history\n[BUILT]" {class: built-soft}

  break_store: "Append-only break store — E-24 break events\nengine-owned duckdb · separate from the canonical store · insert-only, immutable\nno update, no status transition, no delete\n[BUILT — complete and audited]" {class: built-soft}
}

# ─────────────────────────────────────────────────────────
# Observability & fiduciary audit.
# ─────────────────────────────────────────────────────────
obs: "Observability & fiduciary audit" {
  class: group-planned

  langfuse: "Langfuse\nLLM-call traces\n[PLANNED]" {class: planned}

  phoenix: "Arize Phoenix\nworkflow / tool traces\n[PLANNED]" {class: planned}

  export: "Hash-chained audit-journal export\nSHA-256 hash chain · canonical-JSON · JSON-L + manifest · tamper-detecting verifier (pnpm audit-export / audit-verify)\nlocal file (tamper-EVIDENCE) · invokable handler + CLI\n[BUILT — local v0.1 · S3/R2 object-lock immutability + nightly cron PLANNED]" {class: built-soft}
}

# ─────────────────────────────────────────────────────────
# Edges.
# ─────────────────────────────────────────────────────────

# Surfaces reach the substrate ingress.
surfaces.cli -> substrate.engine: "invokes (HTTP ingress)"
surfaces.mcp -> substrate.engine: "ingress" {style: {stroke-dash: 4}}
surfaces.openapi -> substrate.engine: "ingress" {style: {stroke-dash: 4}}
surfaces.ui -> substrate.engine: "ingress — list approvals + resolve the awakeable (approve/reject) + read operation state (BUILT)"
surfaces.ui -> substrate.engine: "admin — list services + the operation journal (BUILT)" {style: {stroke-dash: 4}}

# Surfaces are auto-generated FROM the registered handlers (the typed catalogue is the source).
runtime.bd_services.bdNN -> surfaces.mcp: "catalogue → MCP descriptors + dispatch"
runtime.bd_services.bdNN -> surfaces.openapi: "registered handlers → OpenAPI 3.1"

# Substrate dispatches to registered handlers + owns the journal.
substrate.engine -> runtime.orchestrator: "dispatches / replays (virtual object)"
substrate.engine -> runtime.bd_services: "dispatches (typed RPC)"
substrate.engine -> substrate.journal: "journals every step"

# The orchestrator's internals — every seam BUILT.
runtime.orchestrator -> runtime.plan_loop: "SEAM 1 — plan (journaled once · BUILT + proven)"
runtime.orchestrator -> runtime.arg_resolver: "RESOLVE — abstract args → concrete inputs from the marts (journaled · BUILT + proven)"
runtime.orchestrator -> runtime.approval: "SEAM 3 — gate (durable awakeable pause · no-op for read-only · BUILT + proven)"
runtime.orchestrator -> runtime.fanout: "spawns" {style: {stroke-dash: 4}}

# The NAV-strike workflow REUSES the approval gate at its irreversible publish step (the
# first real high-stakes wiring) and READS the marts for the NAV (no re-implementation):
# it rolls the gross up independently from mart_portfolio_holdings and reconciles it against
# mart_fund_nav's gross (a falsifiable cross-mart check), then ties the NAV identity
# (NAV = gross + accruals − fees).
runtime.nav_workflow -> runtime.approval: "reuses the gate at PUBLISH (first real high-stakes wiring · BUILT + proven)"
runtime.nav_workflow -> data.dbt: "reads mart_portfolio_holdings + mart_fund_nav via navData · cross-mart NAV reconcile · BUILT + proven"

# The resolve step READS the marts (mart_fund_nav + mart_portfolio_holdings via argResolver) to
# derive the SO-09-01/05 concrete tool inputs — the marts-in-the-loop, so the planner's abstract
# args become the tools' real inputs.
runtime.arg_resolver -> data.dbt: "reads mart_fund_nav + mart_portfolio_holdings · abstract args → concrete tool inputs · BUILT + proven"

# The orchestrator dispatches to per-BD services over Restate typed RPC.
runtime.orchestrator -> runtime.bd_services.pytools: "SEAM 2 — dispatch (Restate typed RPC · BUILT + proven)"
runtime.orchestrator -> runtime.bd_services.bdNN: "SEAM 2 — dispatch (parallel allSettled fan-out · execute_so · BUILT + proven)"

# The reconciliation engine reads BOTH sides (the internal dual book + the external comparator
# feeds) from the canonical layer and appends its findings — append-only, never a state mutation.
runtime.bd_services.recon -> data.dbt: "reads the internal dual book (IBOR/ABOR) + the external comparator feeds · BUILT + proven"
runtime.bd_services.recon -> data.break_store: "appends break findings (journaled · insert-only · BUILT + proven)"

# The forward reconciliation stages — designed/planned, not built.
runtime.recon_propose -> data.break_store: "reads unexplained breaks · proposes explanations only" {style: {stroke-dash: 4}}
runtime.recon_correct -> runtime.approval: "the correcting entry rides the high-stakes gate" {style: {stroke-dash: 4}}

# The plan loop selects tools via tool-RAG.
runtime.plan_loop -> runtime.tools: "tool-RAG selects (per task · load-all at the current tool count)"

# Services host / call the typed tools.
runtime.bd_services.pytools -> runtime.tools: "hosts / calls"

# Tools operate over the canonical data layer.
runtime.tools -> data.schemas: "typed over"
runtime.bd_services.pytools -> data.store: "reads / writes (via dbt models)"
data.schemas -> data.dbt: "shapes (Pydantic ↔ staging)"
data.dbt -> data.store: "materialises"

# Observability taps.
runtime.plan_loop -> obs.langfuse: "LLM traces" {style: {stroke-dash: 4}}
runtime.orchestrator -> obs.phoenix: "workflow / tool traces" {style: {stroke-dash: 4}}
substrate.journal -> obs.export: "exports (hash-chained)" {style: {stroke-dash: 4}}

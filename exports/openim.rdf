        <rdfs:range rdf:resource="https://w3id.org/openim/ontology/E-05"/>
        <owl:inverseOf rdf:resource="https://w3id.org/openim/ontology/generates"/>
        <skos:closeMatch rdf:resource="https://spec.edmcouncil.org/fibo/ontology/fibo-fnd-rel-rel/isGeneratedBy"/>
